{
  "manifest_version": 3,
  "name": "Consently",
  "version": "0.1.0",
  "description": "Analyze any privacy policy. See what data apps actually collect before you agree.",
  "permissions": [
    "storage",
    "notifications",
    "scripting",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Consently",
    "default_icon": {
      "32": "public/icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"]
    }
  ],
  "icons": {
    "32": "public/icons/icon32.png",
    "128": "public/icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://consently.vercel.app/*",
      "https://consently-itsaibarrs-projects.vercel.app/*",
      "https://consently-git-main-itsaibarrs-projects.vercel.app/*"
    ]
  }
}
